# CH0SEN1 PICKZ — Server environment variables
#
# Copy this file to ".env" (which is git-ignored) and fill in your real values.
# The server reads these at startup via process.env.<NAME>.
#
# NEVER commit real API keys to source control.

# ── Authentication ────────────────────────────────────────────────────────────
# SESSION_SECRET — a long, random string used to derive session token hashes.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# NODE_ENV — set to "production" in your hosting environment to enable Secure cookies.
# NODE_ENV=production

# ── Admin Seeding ─────────────────────────────────────────────────────────────
# On startup, if ADMIN_EMAIL and ADMIN_PASSWORD are set, the server will
# automatically create (or promote) a user with the 'admin' role.
# This is the recommended way to create your first admin account.
#
# ADMIN_EMAIL    — email address for the admin account
# ADMIN_PASSWORD — password for the admin account (min 8 characters; hashed with bcrypt)
# ADMIN_USERNAME — username for the admin (default: admin)
# ADMIN_NAME     — display name for the admin (default: Admin)
#
# Example:
# ADMIN_EMAIL=owner@example.com
# ADMIN_PASSWORD=a-very-strong-password-here
# ADMIN_USERNAME=siteadmin
# ADMIN_NAME=Site Owner

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.  Required for picks, posts, and authentication.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# The Odds API key — https://the-odds-api.com/
# Used server-side by routes/odds.js and routes/sports.js.
# The browser never sees this value; all calls to the-odds-api.com are
# proxied through /api/odds and /api/sports.
ODDS_API_KEY=YOUR_ODDS_API_KEY_HERE

# NewsAPI.org key — https://newsapi.org/register
# Used server-side by routes/news.js to fetch top sports headlines.
# The browser never sees this value; all calls to newsapi.org are
# proxied through /api/news.
NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE

# PORT (optional) — defaults to 3000
# PORT=3000

# ── SMTP (signup confirmation emails) ────────────────────────────────────────
# These are used by routes/email.js to send verification codes via SMTP.
# Works with any SMTP provider: Gmail (App Passwords), SendGrid, Mailgun, etc.
# If these are not set the app still works — it will just show the code
# on-screen instead of emailing it.
#
# SMTP_HOST   — your SMTP server host   (e.g. smtp.gmail.com)
# SMTP_PORT   — SMTP port               (587 for STARTTLS, 465 for TLS)
# SMTP_USER   — your email address / SMTP username
# SMTP_PASS   — your email password or app-specific password
# SMTP_FROM   — optional "From" label   (e.g. '"ChosenPickz" <noreply@chosenpickz.com>')
#               Defaults to SMTP_USER if not set.
#
# Example for Gmail (requires a Google App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM="ChosenPickz" <youraddress@gmail.com>
